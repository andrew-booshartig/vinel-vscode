{
  "name": "bettervim",
  "displayName": "BetterVim",
  "description": "A native modal-editing state machine for VSCode — not an emulation, not a Neovim bridge. NORMAL-mode keys are discrete keybindings routed to VS Code's own native commands; INSERT mode never touches typing. No shadow undo tree, no `type`-command hijacking — the two root causes behind most VSCodeVim complaints.",
  "version": "0.0.1",
  "publisher": "andrew-booshartig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrew-booshartig/bettervim-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Keymaps"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "betterVim.enterNormal", "title": "BetterVim: Enter NORMAL mode" },
      { "command": "betterVim.enterInsert", "title": "BetterVim: Enter INSERT mode" },
      { "command": "betterVim.moveLeft", "title": "BetterVim: Move left (h)" },
      { "command": "betterVim.moveRight", "title": "BetterVim: Move right (l)" },
      { "command": "betterVim.moveUp", "title": "BetterVim: Move up (k)" },
      { "command": "betterVim.moveDown", "title": "BetterVim: Move down (j)" },
      { "command": "betterVim.wordForward", "title": "BetterVim: Word forward (w)" },
      { "command": "betterVim.wordBackward", "title": "BetterVim: Word backward (b)" },
      { "command": "betterVim.wordEnd", "title": "BetterVim: Word end (e)" },
      { "command": "betterVim.firstNonBlank", "title": "BetterVim: First non-blank (^)" },
      { "command": "betterVim.lineEnd", "title": "BetterVim: Line end ($)" },
      { "command": "betterVim.bufferTop", "title": "BetterVim: Buffer top (gg)" },
      { "command": "betterVim.bufferBottom", "title": "BetterVim: Buffer bottom (G)" },
      { "command": "betterVim.paragraphBackward", "title": "BetterVim: Paragraph backward ({)" },
      { "command": "betterVim.paragraphForward", "title": "BetterVim: Paragraph forward (})" },
      { "command": "betterVim.search", "title": "BetterVim: Search (/)" },
      { "command": "betterVim.opDelete", "title": "BetterVim: Delete operator (d)" },
      { "command": "betterVim.opChange", "title": "BetterVim: Change operator (c)" },
      { "command": "betterVim.opYank", "title": "BetterVim: Yank operator (y)" },
      { "command": "betterVim.deleteToEol", "title": "BetterVim: Delete to end of line (D)" },
      { "command": "betterVim.changeToEol", "title": "BetterVim: Change to end of line (C)" },
      { "command": "betterVim.yankLine", "title": "BetterVim: Yank line (Y)" },
      { "command": "betterVim.cutChar", "title": "BetterVim: Cut character (x)" },
      { "command": "betterVim.pasteAfter", "title": "BetterVim: Paste after (p)" },
      { "command": "betterVim.pasteBefore", "title": "BetterVim: Paste before (P)" },
      { "command": "betterVim.openBelow", "title": "BetterVim: Open line below (o)" },
      { "command": "betterVim.openAbove", "title": "BetterVim: Open line above (O)" },
      { "command": "betterVim.undo", "title": "BetterVim: Undo (u)" },
      { "command": "betterVim.redo", "title": "BetterVim: Redo (Ctrl+R)" }
    ],
    "keybindings": [
      { "command": "-tabout", "key": "tab",
        "when": "editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible" },
      { "command": "tabout", "key": "tab",
        "when": "editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible && !inSnippetMode" },

      { "command": "-tabout-reverse", "key": "shift+tab",
        "when": "config.tabout.enableReverseShiftTab && editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible" },
      { "command": "tabout-reverse", "key": "shift+tab",
        "when": "config.tabout.enableReverseShiftTab && editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible && !inSnippetMode" },

      { "command": "-acceptSelectedSuggestion", "key": "tab" },

      { "command": "tabout", "key": "tab",
        "when": "editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible && !inSnippetMode" },

      { "command": "betterVim.enterNormal", "key": "escape",
        "when": "editorTextFocus" },
      { "command": "betterVim.enterInsert", "key": "i",
        "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.digit0", "key": "0", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit1", "key": "1", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit2", "key": "2", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit3", "key": "3", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit4", "key": "4", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit5", "key": "5", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit6", "key": "6", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit7", "key": "7", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit8", "key": "8", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.digit9", "key": "9", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.moveLeft",  "key": "h",     "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.moveLeft",  "key": "left",  "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.moveDown",  "key": "j",     "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.moveDown",  "key": "down",  "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.moveUp",    "key": "k",     "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.moveUp",    "key": "up",    "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.moveRight", "key": "l",     "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.moveRight", "key": "right", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.wordForward",  "key": "w", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.wordBackward", "key": "b", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.wordEnd",      "key": "e", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.firstNonBlank", "key": "shift+6", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.lineEnd",       "key": "shift+4", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.bufferTop",    "key": "g g",     "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.bufferBottom", "key": "shift+g", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.paragraphBackward", "key": "shift+[", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.paragraphForward",  "key": "shift+]", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.search", "key": "/", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.opDelete", "key": "d", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.opChange", "key": "c", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.opYank",   "key": "y", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.deleteToEol", "key": "shift+d", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.changeToEol", "key": "shift+c", "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.yankLine",    "key": "shift+y", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.cutChar",     "key": "x",       "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.pasteAfter",  "key": "p",       "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.pasteBefore", "key": "shift+p", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.openBelow", "key": "o",       "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.openAbove", "key": "shift+o", "when": "editorTextFocus && betterVim.mode == 'normal'" },

      { "command": "betterVim.undo", "key": "u",      "when": "editorTextFocus && betterVim.mode == 'normal'" },
      { "command": "betterVim.redo", "key": "ctrl+r", "when": "editorTextFocus && betterVim.mode == 'normal'" }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.5.0"
  }
}
