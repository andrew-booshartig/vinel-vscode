{
  "name": "ultra-instinct",
  "displayName": "Ultra Instinct",
  "description": "A ground-up modal editing engine for VSCode — not a Vim emulation. Starts with a smart Tab that never fights snippet tabstops or bracket tabout.",
  "version": "0.0.1",
  "publisher": "andrew-booshartig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrew-booshartig/ultra-instinct-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Keymaps"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ultraInstinct.smartTab",
        "title": "Ultra Instinct: Smart Tab (tabout-aware snippet jump)"
      },
      {
        "command": "ultraInstinct.smartShiftTab",
        "title": "Ultra Instinct: Smart Shift+Tab (tabout-aware snippet jump back)"
      }
    ],
    "keybindings": [
      { "command": "-tabout", "key": "tab",
        "when": "editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible" },
      { "command": "tabout", "key": "tab",
        "when": "editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible && !inSnippetMode" },

      { "command": "-tabout-reverse", "key": "shift+tab",
        "when": "config.tabout.enableReverseShiftTab && editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible" },
      { "command": "tabout-reverse", "key": "shift+tab",
        "when": "config.tabout.enableReverseShiftTab && editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible && !inSnippetMode" },

      { "command": "ultraInstinct.smartTab", "key": "tab",
        "when": "editorTextFocus && inSnippetMode && !editorHasSelection && !editorHasMultipleSelections" },
      { "command": "ultraInstinct.smartShiftTab", "key": "shift+tab",
        "when": "editorTextFocus && inSnippetMode && !editorHasSelection && !editorHasMultipleSelections" },

      { "command": "-acceptSelectedSuggestion", "key": "tab" },

      { "command": "tabout", "key": "tab",
        "when": "editorTextFocus && !editorHasSelection && !editorHasMultipleSelections && suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible && !inSnippetMode" }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.5.0"
  }
}
